    <!-- Audit Modules → Source Layer -->
    <mxCell id="E5" value="fetch data" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;fontSize=10;" edge="1" source="AM" target="SL" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Audit Modules → Publish Bundle: route ABOVE service row to avoid overlap -->
    <mxCell id="E7" value="promote" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;fontSize=10;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="AM" target="PB" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="187" y="222"/>
          <mxPoint x="631" y="222"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Audit Modules → config/assets -->
    <mxCell id="E4" value="reads config" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;endFill=0;fontSize=10;" edge="1" source="AM" target="CA" parent="1">
