    <!-- Source Layer -.-> PublicNode RPC (dashed) -->
    <mxCell id="E10" value="eth_call / getLogs" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;dashed=1;dashPattern=6 4;fontSize=10;" edge="1" source="SL" target="RPC" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Source Layer -.-> Price and Pool APIs (dashed) -->
    <mxCell id="E11" value="prices / pools / quotes" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;dashed=1;dashPattern=6 4;fontSize=10;" edge="1" source="SL" target="PRICE" parent="1">
