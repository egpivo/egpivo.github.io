      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Publish Bundle → artifacts/audits -->
    <mxCell id="E8" value="write bundle" style="edgeStyle=orthogonalEdgeStyle;endArrow=open;endFill=0;fontSize=10;" edge="1" source="PB" target="AA" parent="1">
