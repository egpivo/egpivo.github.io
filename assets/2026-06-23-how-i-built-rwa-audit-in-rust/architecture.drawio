    </mxCell>
    <mxCell id="CS" value="cache/sources" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="360" y="418" width="120" height="56" as="geometry"/>
    </mxCell>
    <mxCell id="AA" value="artifacts/audits" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="552" y="418" width="120" height="56" as="geometry"/>
    </mxCell>

    <!-- ── External APIs ──────────────────────────────────── -->
    <mxCell id="RPC" value="PublicNode RPC&#xa;(eth_call / getLogs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;arcSize=12;" vertex="1" parent="1">
      <mxGeometry x="248" y="558" width="170" height="56" as="geometry"/>
