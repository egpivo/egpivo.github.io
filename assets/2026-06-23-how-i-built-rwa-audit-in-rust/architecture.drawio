      <mxGeometry x="8" y="432" width="82" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="L5" value="External" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#555555;" vertex="1" parent="1">
      <mxGeometry x="8" y="572" width="82" height="40" as="geometry"/>
    </mxCell>

    <!-- ── Operator ──────────────────────────────────────── -->
    <mxCell id="CLI" value="rwa-audit CLI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;arcSize=12;" vertex="1" parent="1">
      <mxGeometry x="310" y="44" width="200" height="52" as="geometry"/>
    </mxCell>

    <!-- ── Dispatcher ─────────────────────────────────────── -->
    <mxCell id="MR" value="Module Runner" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;arcSize=12;" vertex="1" parent="1">
      <mxGeometry x="285" y="148" width="250" height="52" as="geometry"/>
    </mxCell>

    <!-- ── Service layer ──────────────────────────────────── -->
    <mxCell id="AM" value="Audit Modules" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;arcSize=12;" vertex="1" parent="1">
      <mxGeometry x="108" y="272" width="158" height="52" as="geometry"/>
    </mxCell>
    <mxCell id="SL" value="Source Layer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;arcSize=12;" vertex="1" parent="1">
      <mxGeometry x="330" y="272" width="158" height="52" as="geometry"/>
    </mxCell>
    <mxCell id="PB" value="Publish Bundle" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;arcSize=12;" vertex="1" parent="1">
      <mxGeometry x="552" y="272" width="158" height="52" as="geometry"/>
    </mxCell>

    <!-- ── Storage layer ──────────────────────────────────── -->
    <mxCell id="CA" value="config/assets" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="50" y="418" width="120" height="56" as="geometry"/>
    </mxCell>
    <mxCell id="DS" value="data/scratch" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
