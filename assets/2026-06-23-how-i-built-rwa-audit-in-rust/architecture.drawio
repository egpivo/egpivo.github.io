    <mxCell id="PRICE" value="Price &amp; Pool APIs&#xa;(CoinGecko · GeckoTerminal&#xa;Jupiter · ParaSwap · Yahoo)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;arcSize=12;" vertex="1" parent="1">
      <mxGeometry x="448" y="558" width="210" height="56" as="geometry"/>
    </mxCell>

    <!-- ── Edges ───────────────────────────────────────────── -->

    <!-- CLI → Module Runner -->
    <mxCell id="E1" value="run / freeze" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;fontSize=10;" edge="1" source="CLI" target="MR" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Module Runner → Audit Modules -->
    <mxCell id="E2" value="resolve_module" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;fontSize=10;" edge="1" source="MR" target="AM" parent="1">
